# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.venv/
.venv-*/
venv/

# local E2E scratch (venvs, benchmark clones, run artifacts, .env credentials)
e2e/

# cap-evolve run state (per-run, not source)
.capevolve/

# secrets — never commit credentials (RITS_API_KEY, WATSONX_*, ANTHROPIC_API_KEY, …)
.env
.env.*
!.env.example

# OS
.DS_Store
.demo/

# keep the prebuilt dashboard frontend (served at runtime; no node needed)
!dashboard/frontend/dist/
!dashboard/frontend/dist/**

# skillsbench example: local clone + bench cache + run scratch (not committed)
vendor/
.bench_cwd/
.bench_runs/
examples/skillsbench/run/
.cache/

# skillsbench seed skills are Anthropic-licensed — extracted from the SkillsBench clone
# by setup.sh at onboarding time, NOT vendored here (only the README is tracked).
examples/skillsbench/seed_capability/*
!examples/skillsbench/seed_capability/README.md
